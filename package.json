{
  "name": "redline",
  "version": "0.0.0",
  "private": true,
  "description": "Procurement Evaluation Adapter — a Wayfinder plugin integrating womblex + Numbatch.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build --filter=@redline/*",
    "dev": "turbo run dev --filter=@redline/*",
    "lint": "turbo run lint --filter=@redline/*",
    "typecheck": "turbo run typecheck --filter=@redline/*",
    "test": "turbo run test --filter=@redline/*",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.14.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "turbo": "^2.1.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0"
  }
}
