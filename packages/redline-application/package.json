{
  "name": "@redline/redline-application",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Procurement evaluation use-cases. Depends on redline-domain and redline-shared only.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src"
  },
  "dependencies": {
    "@redline/redline-domain": "workspace:*",
    "@redline/redline-shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
